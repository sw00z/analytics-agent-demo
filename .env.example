# ============================================================================
# REQUIRED
# ============================================================================

# Neon Postgres connection string (any Postgres works; Neon is the default).
# Get from console.neon.tech → your project → Connection Details.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# OpenAI API key. The agent uses gpt-4o for SQL generation and gpt-4o-mini
# for session-title generation. Set a monthly spend cap in the OpenAI dashboard
# (≈$20 is plenty for a demo).
OPENAI_API_KEY="sk-..."

# Demo's tenant id. Every analytical table carries tenant_id and the agent's
# execute_sql tool requires `WHERE tenant_id = $TENANT_ID`. The server replaces
# the placeholder with this value. Default: 1.
DEMO_TENANT_ID=1

# ============================================================================
# OPTIONAL: rate limiting (production)
# ============================================================================

# Upstash Redis credentials enable durable per-IP rate limiting in production.
# Without these, the demo falls back to an in-memory limiter (per-instance,
# resets on cold start — fine for local dev, not great for a public URL).
# Get free credentials at upstash.com → create Redis database.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Per-IP requests allowed per hour for /api/agent. Default: 35.
RATE_LIMIT_PER_HOUR=35

# ============================================================================
# OPTIONAL: observability
# ============================================================================

# Langfuse traces every agent run (prompt, tool calls, structured response).
# Without these, the agent runs without observability — no behavior change.
# Get keys at cloud.langfuse.com → settings.
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASEURL="https://cloud.langfuse.com"
